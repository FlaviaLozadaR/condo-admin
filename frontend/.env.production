# Variables para `npm run build` (sirve tanto para el sitio web como para la app
# móvil empaquetada con Capacitor — ambos usan este build).
#
# IMPORTANTE: reemplazar por la URL real del backend desplegado (con HTTPS).
# iOS bloquea HTTP plano, así que esto NO puede ser http://localhost:3001/api.
VITE_API_URL=https://condo-backend-o5av.onrender.com/api
