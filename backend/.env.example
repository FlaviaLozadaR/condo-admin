# Condo Admin — Variables de entorno requeridas
# Copiá este archivo como .env y completá los valores

# JWT — generá un secret largo y aleatorio (ej: openssl rand -base64 48)
JWT_SECRET=cambia_esto_por_un_secret_largo_y_aleatorio

# Brevo — API key (SMTP & API → API Keys) y el correo verificado como remitente
# en Senders, Domains & Dedicated IPs → Senders
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=tu_correo_verificado@gmail.com

# Supabase — del dashboard del proyecto: Settings → API
# SUPABASE_URL = "Project URL"; SUPABASE_SECRET_KEY = "service_role" key (¡secreta, nunca exponerla en el frontend!)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SECRET_KEY=tu_service_role_key

# URLs
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Puerto del servidor (opcional, default 3001)
# PORT=3001

# En el servidor de producción descomentá esta línea
# NODE_ENV=production
